[flake8]
max-line-length = 150
max-complexity = 35
extend-ignore =
    # E203: whitespace before ':' (false positive with slice notation)
    E203,
    # W503: line break before binary operator (conflicts with black)
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
